{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "item_count", "items"],
  "properties": {
    "schema_name": { "const": "reading-candidates" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "reading-candidate-build" },
    "run_id": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reading_candidate_id", "candidate_item_ids", "primary_candidate_item_id", "cluster_type", "cluster_confidence", "canonical_url", "display_title", "display_summary", "source_count", "published_at_range", "aggregate_score", "merge_reason", "needs_review", "run_id"],
        "properties": {
          "reading_candidate_id": { "type": "string" },
          "candidate_item_ids": { "type": "array", "items": { "type": "string" } },
          "primary_candidate_item_id": { "type": "string" },
          "cluster_type": { "type": "string" },
          "cluster_confidence": { "type": "number" },
          "canonical_url": { "type": ["string", "null"] },
          "display_title": { "type": ["string", "null"] },
          "display_summary": { "type": ["string", "null"] },
          "source_count": { "type": "integer", "minimum": 1 },
          "published_at_range": { "type": "object" },
          "aggregate_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "merge_reason": { "type": "string" },
          "needs_review": { "type": "boolean" },
          "run_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
