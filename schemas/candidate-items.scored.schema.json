{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "item_count", "items"],
  "properties": {
    "schema_name": { "const": "candidate-items.scored" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "candidate-score" },
    "run_id": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_item_id", "normalize_status", "filter_status", "freshness_score", "quality_score", "noise_flags", "run_id"],
        "properties": {
          "candidate_item_id": { "type": "string" },
          "normalize_status": { "const": "NORMALIZED" },
          "filter_status": { "enum": ["KEPT", "FILTERED"] },
          "freshness_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "noise_flags": { "type": "array" },
          "run_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
