{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "item_count", "items"],
  "properties": {
    "schema_name": { "const": "candidate-items.normalized" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "candidate-normalize" },
    "run_id": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_item_id", "origin_raw_item_id", "source_adapter_type", "source_id", "source_name", "canonical_url", "url_fingerprint", "title", "normalized_title", "summary", "published_at", "language", "normalize_status", "freshness_score", "quality_score", "noise_flags", "filter_status", "dedup_key", "run_id"],
        "properties": {
          "candidate_item_id": { "type": "string" },
          "origin_raw_item_id": { "type": "string" },
          "source_adapter_type": { "type": "string" },
          "source_id": { "type": ["string", "null"] },
          "source_name": { "type": ["string", "null"] },
          "canonical_url": { "type": ["string", "null"] },
          "url_fingerprint": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "normalized_title": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] },
          "published_at": { "type": ["string", "null"] },
          "language": { "type": "string" },
          "normalize_status": { "const": "NORMALIZED" },
          "freshness_score": { "type": ["integer", "null"] },
          "quality_score": { "type": ["integer", "null"] },
          "noise_flags": { "type": "array" },
          "filter_status": { "enum": ["KEPT", "FILTERED"] },
          "dedup_key": { "type": ["string", "null"] },
          "run_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
