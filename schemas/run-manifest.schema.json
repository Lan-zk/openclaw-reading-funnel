{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "run_status", "pipeline_version", "ruleset_version", "source_config_hash", "step_results", "artifact_index", "counts", "issues"],
  "properties": {
    "schema_name": { "const": "run-manifest" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "run-review" },
    "run_id": { "type": "string" },
    "run_status": { "enum": ["SUCCEEDED", "PARTIAL_SUCCESS", "FAILED"] },
    "pipeline_version": { "type": "string" },
    "ruleset_version": { "type": "string" },
    "source_config_hash": { "type": "string" },
    "step_results": { "type": "array" },
    "artifact_index": { "type": "array" },
    "counts": { "type": "object" },
    "issues": { "type": "array" }
  },
  "additionalProperties": false
}
