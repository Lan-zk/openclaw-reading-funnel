{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "item_count", "items"],
  "properties": {
    "schema_name": { "const": "cluster-plan" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "dedup-cluster" },
    "run_id": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "candidate_item_ids", "primary_candidate_item_id", "cluster_type", "cluster_confidence", "merge_reason", "needs_review"],
        "properties": {
          "cluster_id": { "type": "string" },
          "candidate_item_ids": { "type": "array", "items": { "type": "string" } },
          "primary_candidate_item_id": { "type": "string" },
          "cluster_type": { "enum": ["EXACT_DUPLICATE", "HIGH_SIMILARITY", "SINGLETON"] },
          "cluster_confidence": { "type": "number" },
          "merge_reason": { "type": "string" },
          "needs_review": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
