{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "item_count", "items"],
  "properties": {
    "schema_name": { "const": "raw-source-items" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "source-fetch" },
    "run_id": { "type": "string" },
    "item_count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["raw_item_id", "source_adapter_type", "source_id", "source_name", "origin_item_id", "title", "url", "summary", "author", "published_at", "fetched_at", "raw_payload", "run_id"],
        "properties": {
          "raw_item_id": { "type": "string" },
          "source_adapter_type": { "type": "string" },
          "source_id": { "type": ["string", "null"] },
          "source_name": { "type": ["string", "null"] },
          "origin_item_id": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] },
          "author": { "type": ["string", "null"] },
          "published_at": { "type": ["string", "null"] },
          "fetched_at": { "type": "string" },
          "raw_payload": { "type": "object" },
          "run_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
