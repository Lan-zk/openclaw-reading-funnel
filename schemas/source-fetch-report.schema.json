{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "step_name", "step_status", "continue_recommended", "input_artifacts", "output_artifacts", "counts", "issues", "payload"],
  "properties": {
    "schema_name": { "const": "source-fetch-report" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "const": "source-fetch" },
    "run_id": { "type": "string" },
    "step_name": { "const": "source-fetch" },
    "step_status": { "enum": ["SUCCEEDED", "PARTIAL_SUCCESS", "FAILED"] },
    "continue_recommended": { "type": "boolean" },
    "input_artifacts": { "type": "array" },
    "output_artifacts": { "type": "array" },
    "counts": { "type": "object" },
    "issues": { "type": "array" },
    "payload": {
      "type": "object",
      "required": ["requested_sources", "success_count", "failure_count", "partial_success", "source_results"],
      "properties": {
        "requested_sources": { "type": "array" },
        "success_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "partial_success": { "type": "boolean" },
        "source_results": { "type": "array" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
