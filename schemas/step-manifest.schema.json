{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_name", "schema_version", "generated_at", "produced_by_skill", "run_id", "step_name", "step_status", "continue_recommended", "input_artifacts", "output_artifacts", "counts", "issues", "payload"],
  "properties": {
    "schema_name": { "const": "step-manifest" },
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "produced_by_skill": { "type": "string" },
    "run_id": { "type": "string" },
    "step_name": { "type": "string" },
    "step_status": { "enum": ["SUCCEEDED", "PARTIAL_SUCCESS", "FAILED"] },
    "continue_recommended": { "type": "boolean" },
    "input_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_name", "path", "schema_name", "schema_version", "required"],
        "properties": {
          "artifact_name": { "type": "string" },
          "path": { "type": "string" },
          "schema_name": { "type": "string" },
          "schema_version": { "type": "string" },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "output_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_name", "path", "schema_name", "schema_version", "artifact_role", "consumable_by_downstream", "required_for_next"],
        "properties": {
          "artifact_name": { "type": "string" },
          "path": { "type": "string" },
          "schema_name": { "type": "string" },
          "schema_version": { "type": "string" },
          "artifact_role": { "enum": ["PRIMARY", "AUXILIARY", "FAILURE_REPORT", "HUMAN_REPORT"] },
          "consumable_by_downstream": { "type": "boolean" },
          "required_for_next": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "counts": { "type": "object" },
    "issues": { "type": "array" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
